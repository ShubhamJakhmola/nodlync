<UserControl x:Class="AIHub.Views.LogsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Border Background="{StaticResource CardBrush}" CornerRadius="12" Padding="20" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
            <StackPanel>
                <Grid Margin="0,0,0,16">
                    <TextBlock Text="SYSTEM LOGS" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ComboBox Width="120" SelectedIndex="0" Margin="0,0,8,0" Padding="8,4">
                        <ComboBoxItem Content="Filter: All"/>
                        <ComboBoxItem Content="Filter: Errors"/>
                        <ComboBoxItem Content="Filter: API"/>
                    </ComboBox>
                    <Button Content="Export CSV"
                            Background="{StaticResource SidebarBrush}"
                            Foreground="{StaticResource TextBrush}"
                            Padding="12,4"
                            BorderThickness="0"
                            Command="{Binding ExportCsvCommand}"/>
                    </StackPanel>
                </Grid>
                
                <DataGrid ItemsSource="{Binding Logs}" AutoGenerateColumns="False" Background="Transparent" Foreground="{StaticResource TextBrush}" RowBackground="Transparent" AlternatingRowBackground="{StaticResource SidebarBrush}" HeadersVisibility="Column" GridLinesVisibility="None" BorderThickness="0" FontFamily="Consolas">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="150"/>
                        <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="150"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                        <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

