<UserControl x:Class="AIHub.Views.RegisterPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24" Background="{StaticResource BackgroundBrush}">
        <Border Background="{StaticResource CardBrush}" CornerRadius="12" Padding="40" MaxWidth="400" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="300">
                <TextBlock Text="⚡ AI Hub" FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Create your workspace account" FontSize="14" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,0,0,32"/>
                
                <TextBlock Text="Display Name" FontSize="12" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                <TextBox Text="{Binding DisplayName}" Background="{StaticResource SidebarBrush}" Foreground="{StaticResource TextBrush}" BorderThickness="0" Padding="12" Margin="0,0,0,16"/>
                
                <TextBlock Text="Email Address" FontSize="12" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                <TextBox Text="{Binding Email}" Background="{StaticResource SidebarBrush}" Foreground="{StaticResource TextBrush}" BorderThickness="0" Padding="12" Margin="0,0,0,16"/>
                
                <TextBlock Text="Password" FontSize="12" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                <PasswordBox x:Name="RegisterPasswordBox" Background="{StaticResource SidebarBrush}" Foreground="{StaticResource TextBrush}" BorderThickness="0" Padding="12" Margin="0,0,0,32"/>
                
                <Button Content="{Binding RegisterActionText}" Command="{Binding RegisterCommand}" CommandParameter="{Binding ElementName=RegisterPasswordBox}" Style="{StaticResource PrimaryButtonStyle}" Padding="16" Margin="0,0,0,16"/>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Already have an account?" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,8,0"/>
                    <TextBlock Text="Log in" Foreground="{StaticResource PrimaryBrush}" Cursor="Hand">
                        <TextBlock.InputBindings>
                            <MouseBinding Command="{Binding NavigateLoginCommand}" MouseAction="LeftClick"/>
                        </TextBlock.InputBindings>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

