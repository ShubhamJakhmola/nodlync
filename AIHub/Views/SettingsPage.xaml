<UserControl x:Class="AIHub.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AIHub.Views"
             mc:Ignorable="d" 
             d:DesignHeight="850" d:DesignWidth="1000" Background="{StaticResource BackgroundBrush}">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Workspace Settings" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
            <TextBlock Text="Manage your AI Hub integrations, preferences, and backups." Foreground="{StaticResource TextMutedBrush}" FontSize="14" Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                
                <!-- Status Bar -->
                <Border Background="#204A90E2" BorderThickness="1" BorderBrush="#4A90E2" CornerRadius="6" Padding="12" Margin="0,0,0,24" Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#4A90E2" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </Border>
                <Grid Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,0,20">
                    <TextBlock Text="Loading..." FontSize="14" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Column: AI & Integrations -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="AI Capabilities" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                        
                        <Border Background="{StaticResource CardBrush}" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Default AI Provider" FontSize="12" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                                <ComboBox SelectedItem="{Binding SettingsItem.DefaultAIProvider}" Background="{StaticResource SidebarBrush}" Foreground="{StaticResource TextBrush}" BorderThickness="0" Padding="8" Margin="0,0,0,16">
                                    <ComboBoxItem Content="OpenAI"/>
                                    <ComboBoxItem Content="Anthropic Claude"/>
                                    <ComboBoxItem Content="Gemini"/>
                                </ComboBox>

                                <TextBlock Text="OpenAI API Key (Encrypted)" FontSize="12" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding OpenAIKey}" Background="{StaticResource SidebarBrush}" Foreground="{StaticResource TextBrush}" BorderThickness="0" Padding="10" Margin="0,0,0,16" />

                                <TextBlock Text="Anthropic API Key (Encrypted)" FontSize="12" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding AnthropicKey}" Background="{StaticResource SidebarBrush}" Foreground="{StaticResource TextBrush}" BorderThickness="0" Padding="10" Margin="0,0,0,16" />

                                <TextBlock Text="Gemini API Key (Encrypted)" FontSize="12" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                                <TextBox Text="{Binding GeminiKey}" Background="{StaticResource SidebarBrush}" Foreground="{StaticResource TextBrush}" BorderThickness="0" Padding="10" Margin="0,0,0,8" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Right Column: Preferences & Exports -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Preferences &amp; Backups" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                        
                        <Border Background="{StaticResource CardBrush}" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <CheckBox Content="Enable Auto Updates" IsChecked="{Binding SettingsItem.AutoUpdateEnabled}" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"/>
                                <CheckBox Content="Enable Desktop Notifications" IsChecked="{Binding SettingsItem.NotificationsEnabled}" Foreground="{StaticResource TextBrush}" Margin="0,0,0,24"/>

                                <TextBlock Text="UI Theme" FontSize="12" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                                <ComboBox SelectedItem="{Binding SettingsItem.Theme}" Background="{StaticResource SidebarBrush}" Foreground="{StaticResource TextBrush}" BorderThickness="0" Padding="8" Margin="0,0,0,16">
                                    <ComboBoxItem Content="Dark"/>
                                    <ComboBoxItem Content="Light"/>
                                </ComboBox>

                                <TextBlock Text="Default Project View" FontSize="12" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
                                <ComboBox SelectedItem="{Binding SettingsItem.DefaultProjectView}" Background="{StaticResource SidebarBrush}" Foreground="{StaticResource TextBrush}" BorderThickness="0" Padding="8" Margin="0,0,0,24">
                                    <ComboBoxItem Content="List"/>
                                    <ComboBoxItem Content="Kanban"/>
                                </ComboBox>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                     <TextBlock Text="Last Backup:" FontSize="12" Foreground="{StaticResource TextBrush}" Margin="0,0,8,0"/>
                                     <TextBlock Text="{Binding SettingsItem.LastBackupDate}" FontSize="12" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                </StackPanel>
                                <Button Content="Export Workspace JSON Backup" Command="{Binding ExportBackupCommand}" Style="{StaticResource OutlineButtonStyle}" Padding="12"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                </Grid>

                <Button Content="Save All Settings" Command="{Binding SaveSettingsCommand}" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Right" Padding="24,12" Margin="0,32,0,0"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

