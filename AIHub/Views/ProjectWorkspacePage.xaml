<UserControl x:Class="AIHub.Views.ProjectWorkspacePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Content="Back"
                        Command="{Binding BackCommand}"
                        Style="{StaticResource OutlineButtonStyle}"
                        Padding="12,6"
                        VerticalAlignment="Top"
                        Margin="0,0,16,0"/>

                <StackPanel Grid.Column="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding ProjectName}"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"
                                   VerticalAlignment="Center"/>
                        <Border Background="#14137FEC"
                                BorderBrush="#2B137FEC"
                                BorderThickness="1"
                                CornerRadius="999"
                                Padding="10,6"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>

                    <TextBlock Text="{Binding DescriptionText}"
                               Margin="0,8,0,14"
                               FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"
                               TextWrapping="Wrap"/>

                    <Border Background="#1F92400E"
                            BorderBrush="#D97706"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12,8"
                            Margin="0,0,0,14"
                            Visibility="{Binding WorkspaceNotice, Converter={StaticResource StringToVisibilityConverter}}">
                        <TextBlock Text="{Binding WorkspaceNotice}"
                                   FontSize="12"
                                   Foreground="#F59E0B"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}"
                                         Maximum="100"
                                         Height="10"/>
                            <TextBlock Text="{Binding ProgressText}"
                                       Margin="0,8,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>

                        <ItemsControl Grid.Column="2"
                                      ItemsSource="{Binding TeamAvatars}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="34"
                                            Height="34"
                                            Margin="0,0,8,0"
                                            Background="{StaticResource PrimaryBrush}"
                                            CornerRadius="17"
                                            ToolTip="{Binding Label}">
                                        <TextBlock Text="{Binding Initials}"
                                                   Foreground="White"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Top">
                    <Button Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource OutlineButtonStyle}"
                            Padding="12,6"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Loading workspace..."
                               Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                               Foreground="{StaticResource PrimaryBrush}"
                               Margin="0,0,0,12"/>

                    <TabControl Grid.Row="1"
                                Background="Transparent"
                                BorderThickness="0">
                        <TabItem Header="Overview">
                            <ScrollViewer Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <UniformGrid Columns="4" Margin="0,0,0,20">
                                        <Border Background="{StaticResource SidebarBrush}" CornerRadius="12" Padding="14" Margin="0,0,12,0">
                                            <StackPanel>
                                                <TextBlock Text="Start Date" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                                <TextBlock Text="{Binding StartDateText}" Margin="0,8,0,0" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="{StaticResource SidebarBrush}" CornerRadius="12" Padding="14" Margin="0,0,12,0">
                                            <StackPanel>
                                                <TextBlock Text="Last Updated" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                                <TextBlock Text="{Binding LastUpdatedText}" Margin="0,8,0,0" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="{StaticResource SidebarBrush}" CornerRadius="12" Padding="14" Margin="0,0,12,0">
                                            <StackPanel>
                                                <TextBlock Text="Total Hours" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                                <TextBlock Text="{Binding TotalHoursText}" Margin="0,8,0,0" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Background="{StaticResource SidebarBrush}" CornerRadius="12" Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="Velocity" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                                <TextBlock Text="{Binding VelocityText}" Margin="0,8,0,0" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>

                                    <Border Background="{StaticResource SidebarBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,20">
                                        <StackPanel>
                                            <TextBlock Text="Project Description" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                            <TextBlock Text="{Binding DescriptionText}" Margin="0,10,0,0" FontSize="12" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="{StaticResource SidebarBrush}" CornerRadius="12" Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="Daily Work Log" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                            <TextBlock Text="Capture progress and post it straight into the project timeline."
                                                       Margin="0,6,0,16"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       TextWrapping="Wrap"/>

                                            <TextBlock Text="Completed Work" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                                            <TextBox Text="{Binding CompletedWork, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" Padding="10,8" AcceptsReturn="True" TextWrapping="Wrap" Height="80"/>

                                            <TextBlock Text="Next Steps" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                                            <TextBox Text="{Binding NextSteps, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" Padding="10,8" AcceptsReturn="True" TextWrapping="Wrap" Height="80"/>

                                            <TextBlock Text="Blockers" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                                            <TextBox Text="{Binding DailyBlockers, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" Padding="10,8" AcceptsReturn="True" TextWrapping="Wrap" Height="70"/>

                                            <TextBlock Text="Notes" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                                            <TextBox Text="{Binding DailyNotes, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,16" Padding="10,8" AcceptsReturn="True" TextWrapping="Wrap" Height="70"/>

                                            <Button Content="Post Daily Log"
                                                    Command="{Binding PostDailyLogCommand}"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    HorizontalAlignment="Left"
                                                    Padding="18,8"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Milestones">
                            <ScrollViewer Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Milestones}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource SidebarBrush}" CornerRadius="12" Padding="14" Margin="0,0,0,12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding Description}" Margin="0,6,0,0" FontSize="12" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                        <TextBlock Text="{Binding DueDate, StringFormat='{}{0:MMM dd, yyyy}'}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right"/>
                                                        <TextBlock Text="{Binding DisplayStatus, StringFormat=Status: {0}}" Margin="0,8,0,0" FontSize="11" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Right"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Tasks">
                            <ScrollViewer Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Tasks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource SidebarBrush}" CornerRadius="12" Padding="14" Margin="0,0,0,12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding Notes}" Margin="0,6,0,0" FontSize="12" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                        <TextBlock Text="{Binding Status}" FontSize="11" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Right"/>
                                                        <TextBlock Text="{Binding DueDate, StringFormat='Due: {0:MMM dd, yyyy}'}" Margin="0,8,0,0" FontSize="11" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Activity">
                            <ScrollViewer Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding ActivityTimeline}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="18"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="10"
                                                        Height="10"
                                                        Margin="0,6,8,0"
                                                        Background="{StaticResource PrimaryBrush}"
                                                        CornerRadius="5"/>
                                                <Border Grid.Column="1"
                                                        Background="{StaticResource SidebarBrush}"
                                                        CornerRadius="12"
                                                        Padding="14">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                                        <TextBlock Text="{Binding Description}" Margin="0,6,0,0" FontSize="12" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding TimestampText}" Margin="0,8,0,0" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Reports">
                            <Grid Margin="0,16,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <Button Content="Today's Report"
                                            Command="{Binding GenerateTodayReportCommand}"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Padding="16,6"
                                            Margin="0,0,12,0"/>
                                    <Button Content="Full Project Report"
                                            Command="{Binding GenerateFullReportCommand}"
                                            Style="{StaticResource OutlineButtonStyle}"
                                            Padding="16,6"
                                            Margin="0,0,12,0"/>
                                    <Button Content="Export to PDF / DOC"
                                            Command="{Binding ExportWorkspaceReportCommand}"
                                            Style="{StaticResource OutlineButtonStyle}"
                                            Padding="16,6"/>
                                </StackPanel>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Reports}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource SidebarBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding ReportDate, StringFormat='Report: {0:MMM dd, yyyy HH:mm}'}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                                        <TextBlock Text="{Binding CompletedTasks.Count, StringFormat='Completed Tasks: {0}'}" Margin="0,8,0,0" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                                                        <TextBlock Text="{Binding NextSteps.Count, StringFormat='Next Steps: {0}'}" Margin="0,4,0,0" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                                                        <TextBlock Text="{Binding Blockers.Count, StringFormat='Blockers: {0}'}" Margin="0,4,0,0" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Team">
                            <ScrollViewer Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="Team Members" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"/>
                                    <ItemsControl ItemsSource="{Binding TeamMembers}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource SidebarBrush}" CornerRadius="12" Padding="14" Margin="0,0,0,12">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Width="34" Height="34" Background="{StaticResource PrimaryBrush}" CornerRadius="17" Margin="0,0,12,0">
                                                            <TextBlock Text="{Binding Initials}" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" FontWeight="Bold"/>
                                                        </Border>
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                                            <TextBlock Text="{Binding Role}" Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="Open Blockers" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,12,0,12"/>
                                    <ItemsControl ItemsSource="{Binding Blockers}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource SidebarBrush}" CornerRadius="12" Padding="14" Margin="0,0,0,12">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Description}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding DisplayStatus, StringFormat=Status: {0}}" Margin="0,6,0,0" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>

            <StackPanel Grid.Column="2">
                <Border Background="{StaticResource CardBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="18"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Milestones" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="{Binding CompletedMilestonesCount, StringFormat='Completed: {0}'}" Margin="0,12,0,0" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock Text="{Binding InProgressMilestonesCount, StringFormat='In Progress: {0}'}" Margin="0,6,0,0" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock Text="{Binding UpcomingMilestonesCount, StringFormat='Upcoming: {0}'}" Margin="0,6,0,0" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>

                        <ItemsControl ItemsSource="{Binding MilestoneHighlights}" Margin="0,14,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource SidebarBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding DisplayStatus, StringFormat=Status: {0}}" Margin="0,6,0,0" FontSize="11" Foreground="{StaticResource PrimaryBrush}"/>
                                            <TextBlock Text="{Binding DueDate, StringFormat='Date: {0:MMM dd, yyyy}'}" Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource CardBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="18"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Quick Reports" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="{Binding QuickReportHint}"
                                   Margin="0,10,0,16"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap"/>
                        <Button Content="Today's Report"
                                Command="{Binding GenerateTodayReportCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Padding="14,6"
                                Margin="0,0,0,10"/>
                        <Button Content="Full Project Report"
                                Command="{Binding GenerateFullReportCommand}"
                                Style="{StaticResource OutlineButtonStyle}"
                                Padding="14,6"
                                Margin="0,0,0,10"/>
                        <Button Content="Export to PDF / DOC"
                                Command="{Binding ExportWorkspaceReportCommand}"
                                Style="{StaticResource OutlineButtonStyle}"
                                Padding="14,6"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource CardBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Text="Activity" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                        <ItemsControl ItemsSource="{Binding ActivityTimeline}" Margin="0,14,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource SidebarBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Description}" Margin="0,6,0,0" FontSize="11" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding TimestampText}" Margin="0,6,0,0" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
