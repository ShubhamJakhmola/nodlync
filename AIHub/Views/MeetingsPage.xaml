<UserControl x:Class="AIHub.Views.MeetingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Border Background="{StaticResource CardBrush}" CornerRadius="12" Padding="20" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
            <StackPanel>
                <Grid Margin="0,0,0,16">
                    <TextBlock Text="MEETINGS HUB" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                    <Button Content="âž• Add Meeting"
                            Style="{StaticResource PrimaryButtonStyle}"
                            HorizontalAlignment="Right"
                            FontSize="12"
                            Command="{Binding AddMeetingCommand}"/>
                </Grid>
                
                <ItemsControl ItemsSource="{Binding Meetings}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource SidebarBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,12" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="ðŸŽ¥" FontSize="20" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Platform}" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                                        <TextBlock Text="{Binding Notes}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0" FontStyle="Italic"/>
                                    </StackPanel>
                                    <Button Grid.Column="2"
                                            Content="Launch Meeting"
                                            Background="#2563eb"
                                            Foreground="White"
                                            Padding="12,6"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Command="{Binding DataContext.LaunchMeetingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding MeetingUrl}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

