<UserControl x:Class="AIHub.Views.ReportsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Border Background="{StaticResource CardBrush}" CornerRadius="12" Padding="20" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
            <StackPanel>
                <Grid Margin="0,0,0,16">
                    <TextBlock Text="DAILY REPORTS" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Generate Today's Report" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" FontSize="12"/>
                        <Button Content="Export" Background="{StaticResource SidebarBrush}" Foreground="{StaticResource TextBrush}" Padding="12,6" BorderThickness="0"/>
                    </StackPanel>
                </Grid>
                
                <Border Background="{StaticResource SidebarBrush}" CornerRadius="12" Padding="20" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                    <StackPanel>
                        <TextBlock Text="Report: Mobile App Dev (Drafting)" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>
                        <TextBlock Text="COMPLETED TASKS" FontSize="12" FontWeight="Bold" Foreground="{StaticResource GreenBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="- Refactored auth middleware" FontSize="12" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4"/>
                        <TextBlock Text="- Updated iOS dependencies" FontSize="12" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>

                        <TextBlock Text="NEXT STEPS" FontSize="12" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="- Push v2.4.0 build to AppStore Connect" FontSize="12" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>

                        <TextBlock Text="BLOCKERS" FontSize="12" FontWeight="Bold" Foreground="Red" Margin="0,0,0,8"/>
                        <TextBlock Text="- Waiting on marketing assets for screenshots" FontSize="12" Foreground="{StaticResource TextBrush}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

