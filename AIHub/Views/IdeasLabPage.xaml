<UserControl x:Class="AIHub.Views.IdeasLabPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        
        <Border Grid.Column="0" Background="{StaticResource CardBrush}" CornerRadius="12" Padding="20" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}" Margin="0,0,16,0">
            <StackPanel>
                <TextBlock Text="AI PROVIDER SETUP" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                <ComboBox ItemsSource="{Binding Providers}" SelectedItem="{Binding SelectedProvider}" Margin="0,0,0,16" Padding="8,6" Background="{StaticResource SidebarBrush}" Foreground="{StaticResource TextBrush}"/>
                
                <TextBlock Text="GENERATION MODES" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                <Button Content="ðŸ’¬ Generate Text"
                        Style="{StaticResource NavButtonStyle}"
                        Margin="0,0,0,4"
                        Background="{StaticResource SidebarBrush}"
                        Foreground="{StaticResource TextBrush}"
                        Command="{Binding GenerateIdeasCommand}"/>
                <Button Content="ðŸ“Š Generate Flow Diagram"
                        Style="{StaticResource NavButtonStyle}"
                        Margin="0,0,0,4"
                        Command="{Binding GenerateFlowDiagramCommand}"/>
                <Button Content="âš™ï¸ Automation Ideas"
                        Style="{StaticResource NavButtonStyle}"
                        Margin="0,0,0,4"
                        Command="{Binding ShowAutomationIdeasCommand}"/>
                <Button Content="ðŸ—ï¸ Project Ideas"
                        Style="{StaticResource NavButtonStyle}"
                        Margin="0,0,0,4"
                        Command="{Binding ShowProjectIdeasCommand}"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="{StaticResource CardBrush}" CornerRadius="12" Padding="20" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="PLAYGROUND WORKSPACE" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>
                
                <TextBox Grid.Row="1"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Background="{StaticResource SidebarBrush}"
                         Foreground="{StaticResource TextBrush}"
                         BorderThickness="0"
                         Padding="16"
                         Margin="0,0,0,16"
                         Text="{Binding PlaygroundText, UpdateSourceTrigger=PropertyChanged}" />
                
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Clear"
                            Background="{StaticResource SidebarBrush}"
                            Foreground="{StaticResource TextBrush}"
                            Padding="16,8"
                            Margin="0,0,8,0"
                            BorderThickness="0"
                            Command="{Binding ClearPlaygroundCommand}"/>
                    <Button Content="âœ¨ Generate"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Padding="16,8"
                            Command="{Binding GenerateIdeasCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

